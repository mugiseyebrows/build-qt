From 48e15ecf825cda615b989c5ace829549b629eaa1 Mon Sep 17 00:00:00 2001
From: Doronin Stanislav <mugisbrows@gmail.com>
Date: Wed, 25 Mar 2026 20:22:16 +0300
Subject: [PATCH] missin min and max def

---
 qtbase/src/plugins/platforms/windows/qwindowswindow.cpp | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/qtbase/src/plugins/platforms/windows/qwindowswindow.cpp b/qtbase/src/plugins/platforms/windows/qwindowswindow.cpp
index 731673b..341c501 100644
--- a/qtbase/src/plugins/platforms/windows/qwindowswindow.cpp
+++ b/qtbase/src/plugins/platforms/windows/qwindowswindow.cpp
@@ -44,6 +44,12 @@
 #include <QtCore/qoperatingsystemversion.h>
 
 #include <dwmapi.h>
+
+#if defined(_MSC_VER)
+#define min(a, b) ((a) < (b) ? (a) : (b))
+#define max(a, b) ((a) > (b) ? (a) : (b))
+#endif
+
 #include <gdiplus.h>
 
 #if QT_CONFIG(vulkan)
